    "awesome-claude-code-agents@awesome-claude-code-agents": true,
    "claude-code-mcp@claude-code-mcp": true,
    "claude-squad@claude-squad": true,
    "swarm-sdk@swarm-sdk": true,
    "prompt-improver@severity1-marketplace": true
  },
